let cartCount = 0;

function addToCart() {
    let colors = document.getElementsByName("c");
    let sizes = document.getElementsByName("s");

    let selectedColor = "";
    let selectedSize = "";

    for (let i = 0; i < colors.length; i++) {
        if (colors[i].checked) {
            selectedColor = colors[i].parentElement.textContent.trim();
        }
    }

    for (let i = 0; i < sizes.length; i++) {
        if (sizes[i].checked) {
            selectedSize = sizes[i].parentElement.textContent.trim();
        }
    }

    let msg = document.getElementById("msg");

    if (selectedColor === "" || selectedSize === "") {
        msg.innerHTML = " Please select color and size!";
        msg.style.color = "red";
        return;
    }

    cartCount++;
    document.getElementById("cartCount").innerText = cartCount;

    msg.innerHTML = ` Added: ${selectedColor} | Size: ${selectedSize}`;
    msg.style.color = "green";

    alert("Item added to cart ");

    // reset selection
    colors.forEach(c => c.checked = false);
    sizes.forEach(s => s.checked = false);
}
